datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}


enum UserRole {
  CITIZEN
  FIELD_OFFICER
  DISTRICT_COLLECTOR
  STATE_ADMIN
}

enum GrievanceStatus {
  REPORTED
  VERIFIED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  DUPLICATE
}

model User {
  id               String           @id @default(uuid())
  aadhaarHash      String           @unique
  phoneNumber      String           @unique
  fullName         String
  dateOfBirth      DateTime
  gender           String
  role             UserRole         @default(CITIZEN)
  primaryLanguage  String           @default("en")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  profile          UserProfile?
  documents        DigiVaultDocument[]
  applications     SchemeApplication[]
  reportedGrievances Grievance[]    @relation("ReporterGrievances")
  assignedGrievances Grievance[]    @relation("OfficerGrievances")
  scamAlerts       ScamAlert[]

  @@map("users")
}

model UserProfile {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  annualIncome       Decimal  @db.Decimal(12, 2)
  occupation         String?
  isDifferentlyAbled Boolean  @default(false)
  casteCategory      String?
  hasBplCard         Boolean  @default(false)
  landHoldingHectares Decimal @default(0.0) @db.Decimal(6, 2)
  latitude           Float?
  longitude          Float?
  state              String?
  district           String?

  @@map("user_profiles")
}

model DigiVaultDocument {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType      String   // e.g. "AADHAAR", "INCOME_CERT", "CASTE_CERT"
  documentHash      String
  fileUrl           String
  isVerified        Boolean  @default(false)
  extractedMetadata Json?    // Raw OCR results key-value pairs
  expiryDate        DateTime?
  createdAt         DateTime @default(now())

  @@map("digivault_documents")
}

model Scheme {
  id                  String              @id @default(uuid())
  title               String
  ministry            String
  description         String
  benefitsSummary     String
  rulesVectorId       String?             // Index in Pinecone DB
  eligibilityCriteria Json                // Dynamic constraints JSON
  applicationDeadline DateTime?
  createdAt           DateTime            @default(now())
  applications        SchemeApplication[]

  @@map("schemes")
}

model SchemeApplication {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeId           String
  scheme             Scheme   @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  status             String   @default("submitted") // "submitted", "under_review", "approved", "rejected"
  aiEligibilityScore Float    @default(0.0)
  submittedData      Json
  remarks            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("scheme_applications")
}

model Grievance {
  id                     String          @id @default(uuid())
  reporterId             String
  reporter               User            @relation("ReporterGrievances", fields: [reporterId], references: [id], onDelete: Cascade)
  category               String          // e.g., "pothole", "sanitation", "electricity"
  description            String?
  mediaUrl               String?
  latitude               Float
  longitude              Float
  formattedAddress       String?
  status                 GrievanceStatus @default(REPORTED)
  // AI calculated based on vulnerability + impact
  priorityScore          Float           @default(0.00)

  // Sentiment analysis of report text
  sentimentScore         Float?
  assignedOfficerId      String?
  assignedOfficer        User?           @relation("OfficerGrievances", fields: [assignedOfficerId], references: [id])
  estimatedResolutionTime DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@map("grievances")
}

model ScamAlert {
  id              String   @id @default(uuid())
  reportedContent String
  verdict         String   @default("analyzing") // "safe", "scam", "suspicious"
  aiReasoning     String?
  reportedById    String?
  reportedBy      User?    @relation(fields: [reportedById], references: [id])
  createdAt       DateTime @default(now())

  @@map("scam_alerts")
}
